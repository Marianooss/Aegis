{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MedicalRecordsSummarizerOutput",
  "description": "Structured output from the Medical Records Summarizer agent",
  "type": "object",
  "required": [
    "patient_demographics",
    "diagnoses",
    "medications",
    "allergies",
    "vital_signs",
    "laboratory_values",
    "critical_findings",
    "clinical_plan",
    "summary_text"
  ],
  "properties": {
    "patient_demographics": {
      "type": "object",
      "properties": {
        "age": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 150
        },
        "sex": {
          "type": ["string", "null"],
          "enum": ["male", "female", "other", null]
        },
        "relevant_history": {
          "type": ["string", "null"]
        }
      }
    },
    "diagnoses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["diagnosis", "status"],
        "properties": {
          "diagnosis": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["confirmed", "suspected", "differential", "ruled_out"]
          },
          "icd10": {
            "type": ["string", "null"],
            "pattern": "^[A-Z][0-9]{2}(\\.[0-9]{1,2})?$"
          }
        }
      }
    },
    "medications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "dose": {
            "type": ["string", "null"]
          },
          "frequency": {
            "type": ["string", "null"]
          },
          "route": {
            "type": ["string", "null"],
            "enum": ["oral", "IV", "IM", "SC", "topical", "other", null]
          }
        }
      }
    },
    "allergies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["allergen"],
        "properties": {
          "allergen": {
            "type": "string",
            "minLength": 1
          },
          "reaction": {
            "type": ["string", "null"]
          },
          "severity": {
            "type": ["string", "null"],
            "enum": ["mild", "moderate", "severe", "unknown", null]
          }
        }
      }
    },
    "vital_signs": {
      "type": "object",
      "properties": {
        "blood_pressure": {
          "type": ["string", "null"]
        },
        "heart_rate": {
          "type": ["string", "null"]
        },
        "temperature": {
          "type": ["string", "null"]
        },
        "respiratory_rate": {
          "type": ["string", "null"]
        },
        "oxygen_saturation": {
          "type": ["string", "null"]
        }
      }
    },
    "laboratory_values": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test", "value"],
        "properties": {
          "test": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": ["string", "number"]
          },
          "unit": {
            "type": ["string", "null"]
          },
          "reference_range": {
            "type": ["string", "null"]
          },
          "flag": {
            "type": ["string", "null"],
            "enum": ["normal", "low", "high", "critical", null]
          }
        }
      }
    },
    "critical_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding", "urgency"],
        "properties": {
          "finding": {
            "type": "string",
            "minLength": 1
          },
          "urgency": {
            "type": "string",
            "enum": ["immediate", "urgent", "routine"]
          },
          "source": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "clinical_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "timeframe": {
            "type": ["string", "null"]
          },
          "responsible": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "summary_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
