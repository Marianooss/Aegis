# Aegis — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Anthropic Claude API — Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# UiPath Personal Access Token — Required for UiPath API integration
UIPath_TOKEN=your-uipath-pat-here

# Optional fallback LLMs (not used by default)
# GEMINI_API_KEY=your-gemini-key (optional fallback)
# GROQ_API_KEY=your-groq-key (optional fallback)
# USE_GROQ=false
